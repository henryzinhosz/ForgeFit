
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Perfil do usuário e metas diárias.",
      "properties": {
        "id": { "type": "string" },
        "weight": { "type": "number" },
        "height": { "type": "number" },
        "age": { "type": "number" },
        "gender": { "type": "string", "enum": ["Masculino", "Feminino"] },
        "dailyWaterGoal": { "type": "number" },
        "dailyProteinGoal": { "type": "number" },
        "calorieGoal": { "type": "number" }
      }
    },
    "Workout": {
      "title": "Workout",
      "type": "object",
      "description": "Exercício agendado na rotina semanal (Plano Padrão).",
      "properties": {
        "exerciseId": { "type": "string" },
        "title": { "type": "string" },
        "sets": { "type": "string" },
        "reps": { "type": "string" },
        "day": { "type": "string" },
        "completed": { "type": "boolean" }
      }
    },
    "WorkoutLog": {
      "title": "WorkoutLog",
      "type": "object",
      "description": "Registro real de execução de um exercício.",
      "properties": {
        "workoutId": { "type": "string" },
        "exerciseId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "actualSets": { "type": "number" },
        "actualReps": { "type": "number" },
        "actualWeight": { "type": "number" },
        "actualDistance": { "type": "number" },
        "actualDuration": { "type": "string" },
        "restTime": { "type": "string" }
      }
    },
    "Metric": {
      "title": "Metric",
      "type": "object",
      "description": "Dados de progresso (peso e cargas máximas).",
      "properties": {
        "type": { "type": "string", "enum": ["weight", "maxLoad", "session_completed"] },
        "value": { "type": "number" },
        "exerciseName": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      }
    },
    "WaterLog": {
      "title": "WaterLog",
      "type": "object",
      "description": "Registro de consumo de água.",
      "properties": {
        "date": { "type": "string" },
        "amount": { "type": "number" }
      }
    },
    "Meal": {
      "title": "Meal",
      "type": "object",
      "description": "Registro de alimentação.",
      "properties": {
        "name": { "type": "string" },
        "calories": { "type": "number" },
        "protein": { "type": "number" },
        "slot": { "type": "string" },
        "date": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Silo de dados do usuário."
    },
    "/users/{userId}/workouts/{workoutId}": {
      "schema": { "$ref": "#/backend/entities/Workout" },
      "description": "Exercícios planejados (Plano Padrão)."
    },
    "/users/{userId}/logs/{logId}": {
      "schema": { "$ref": "#/backend/entities/WorkoutLog" },
      "description": "Histórico de execução real."
    },
    "/users/{userId}/metrics/{metricId}": {
      "schema": { "$ref": "#/backend/entities/Metric" },
      "description": "Peso e recordes de carga."
    },
    "/users/{userId}/water/{waterId}": {
      "schema": { "$ref": "#/backend/entities/WaterLog" },
      "description": "Histórico de água."
    },
    "/users/{userId}/meals/{mealId}": {
      "schema": { "$ref": "#/backend/entities/Meal" },
      "description": "Histórico de refeições."
    }
  }
}
