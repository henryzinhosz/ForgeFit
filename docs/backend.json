
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Perfil do usuário e metas diárias.",
      "properties": {
        "id": { "type": "string" },
        "weight": { "type": "number" },
        "height": { "type": "number" },
        "age": { "type": "number" },
        "gender": { "type": "string", "enum": ["Masculino", "Feminino"] },
        "dailyWaterGoal": { "type": "number" },
        "dailyProteinGoal": { "type": "number" }
      }
    },
    "Workout": {
      "title": "Workout",
      "type": "object",
      "description": "Exercício agendado na rotina semanal.",
      "properties": {
        "exerciseId": { "type": "string" },
        "title": { "type": "string" },
        "sets": { "type": "string" },
        "reps": { "type": "string" },
        "day": { "type": "string" },
        "completed": { "type": "boolean" }
      }
    },
    "Metric": {
      "title": "Metric",
      "type": "object",
      "description": "Dados de progresso (peso e cargas máximas).",
      "properties": {
        "type": { "type": "string", "enum": ["weight", "maxLoad"] },
        "value": { "type": "number" },
        "exerciseName": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      }
    },
    "WaterLog": {
      "title": "WaterLog",
      "type": "object",
      "description": "Registro de consumo de água.",
      "properties": {
        "date": { "type": "string" },
        "amount": { "type": "number" }
      }
    },
    "Meal": {
      "title": "Meal",
      "type": "object",
      "description": "Registro de alimentação no rancho.",
      "properties": {
        "name": { "type": "string" },
        "calories": { "type": "number" },
        "protein": { "type": "number" },
        "slot": { "type": "string" },
        "date": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Documento raiz do usuário."
    },
    "/users/{userId}/workouts/{workoutId}": {
      "schema": { "$ref": "#/backend/entities/Workout" },
      "description": "Lista de exercícios agendados."
    },
    "/users/{userId}/metrics/{metricId}": {
      "schema": { "$ref": "#/backend/entities/Metric" },
      "description": "Registros de peso e recordes de carga."
    },
    "/users/{userId}/water/{waterId}": {
      "schema": { "$ref": "#/backend/entities/WaterLog" },
      "description": "Histórico de hidratação."
    },
    "/users/{userId}/meals/{mealId}": {
      "schema": { "$ref": "#/backend/entities/Meal" },
      "description": "Histórico de alimentação."
    }
  }
}
