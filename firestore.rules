rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SILO DE DADOS DO USUÁRIO (ESTRUTURA ABSOLUTA)
     * Garante que o usuário autenticado tenha acesso total e irrestrito
     * a qualquer documento ou subcoleção dentro do seu próprio ID.
     * O uso de {document=**} resolve erros de listagem em subcoleções.
     */
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    /**
     * EXERCÍCIOS GLOBAIS (LEITURA PÚBLICA PARA USUÁRIOS LOGADOS)
     */
    match /exercises/{exerciseId} {
      allow read: if request.auth != null;
    }

    /**
     * EXERCÍCIOS PERSONALIZADOS
     */
    match /custom_exercises/{exerciseId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (resource == null || resource.data.creatorUserId == request.auth.uid);
    }
  }
}