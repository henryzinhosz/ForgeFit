rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SILO DE DADOS DO USUÁRIO (ESTRUTURA EXPLÍCITA)
     * Regras detalhadas para evitar erros de 'list' em subcoleções.
     */
    match /users/{userId} {
      // Permissões para o documento de perfil do usuário
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Permissões explícitas para subcoleções
      // Isso garante que consultas (queries) de listagem funcionem corretamente
      
      match /workouts/{workoutId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /metrics/{metricId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /water/{waterId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /meals/{mealId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Fallback para qualquer outra subcoleção futura
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    /**
     * EXERCÍCIOS GLOBAIS (LEITURA PÚBLICA PARA AUTENTICADOS)
     */
    match /exercises/{exerciseId} {
      allow read: if request.auth != null;
    }

    /**
     * EXERCÍCIOS PERSONALIZADOS
     */
    match /custom_exercises/{exerciseId} {
      allow read, write: if request.auth != null;
    }
  }
}