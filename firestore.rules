rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SILO DE DADOS DO USUÁRIO (MODELO RECURSIVO ABSOLUTO)
     * Garante que o dono do UID tenha acesso total (get, list, create, update, delete)
     * a qualquer documento dentro do seu diretório /users/{userId}.
     */
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // O curinga {document=**} permite que qualquer subcoleção (metrics, workouts, etc.)
      // herde a permissão de leitura e escrita do dono do silo.
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    /**
     * EXERCÍCIOS GLOBAIS
     */
    match /exercises/{exerciseId} {
      allow read: if request.auth != null;
    }

    match /custom_exercises/{exerciseId} {
      allow read, write: if request.auth != null;
    }
  }
}