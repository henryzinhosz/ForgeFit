
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * REGRAS DE SILO DO USUÁRIO
     * Estrutura aninhada para garantir que o proprietário tenha acesso total
     * tanto ao documento raiz quanto a todas as subcoleções (metrics, workouts, water, meals).
     */
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    /**
     * EXERCÍCIOS GLOBAIS
     */
    match /exercises/{exerciseId} {
      allow read: if request.auth != null;
    }

    /**
     * EXERCÍCIOS PERSONALIZADOS
     */
    match /custom_exercises/{exerciseId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.creatorUserId == request.auth.uid);
    }
    
    // Deploy trigger: Refactor para garantir listagem de subcoleções privadas sem erro de permissão.
  }
}
