rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FUNÇÕES AUXILIARES
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * EXERCÍCIOS GLOBAIS
     */
    match /exercises/{exerciseId} {
      allow read: if isSignedIn();
    }

    /**
     * SILO PRIVADO DO USUÁRIO
     * Regra direta e recursiva: se o caminho começa com /users/{userId},
     * e o UID do usuário logado for igual a esse userId, ele tem acesso total.
     */
    match /users/{userId}/{allPaths=**} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Documento de perfil do usuário (raiz do silo)
     */
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    /**
     * COMPATIBILIDADE: Exercícios personalizados legados
     */
    match /custom_exercises/{exerciseId} {
      allow read, write: if isSignedIn() && resource.data.creatorUserId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.creatorUserId == request.auth.uid;
    }
  }
}