rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE SECURITY PHILOSOPHY
     * This ruleset implements a strict User-Ownership Model. All user-generated content is segregated
     * under private user-specific paths (/users/{userId}/...).
     */

    // --- Helper Functions ---

    /**
     * @description Checks if the request is made by an authenticated user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's ID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks ownership and ensures the document exists for state-changing operations.
     */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /**
     * @description Ensures a field is not changed during an update.
     */
    function isUnchanged(fieldName) {
      return request.resource.data[fieldName] == resource.data[fieldName];
    }

    // --- Collection Rules ---

    /**
     * @description Global pre-loaded exercises. Read-only for all authenticated users.
     */
    match /exercises/{exerciseId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /**
     * @description User profile documents.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && isUnchanged('id');
      allow delete: if isExistingOwner(userId);

      /**
       * @description Flat collections for workouts, water, meals, and metrics.
       * These are owned and managed by the specific user.
       */
      match /workouts/{id} {
        allow read, write: if isOwner(userId);
      }
      match /water/{id} {
        allow read, write: if isOwner(userId);
      }
      match /meals/{id} {
        allow read, write: if isOwner(userId);
      }
      match /metrics/{id} {
        allow read, write: if isOwner(userId);
      }

      // Maintain legacy paths from backend.json for compatibility
      match /custom_exercises/{exerciseId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.creatorUserId == userId;
        allow update: if isExistingOwner(userId) && isUnchanged('creatorUserId');
        allow delete: if isExistingOwner(userId);
      }

      match /workout_plans/{planId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);

        match /planned_days/{dayId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.userId == userId;
          allow update: if isExistingOwner(userId) && isUnchanged('userId');
          allow delete: if isExistingOwner(userId);

          match /planned_exercises/{plannedExerciseId} {
            allow get, list: if isOwner(userId);
            allow create: if isOwner(userId) && request.resource.data.userId == userId;
            allow update: if isExistingOwner(userId) && isUnchanged('userId');
            allow delete: if isExistingOwner(userId);
          }
        }
      }

      match /weekly_status/{statusId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);
      }

      match /performance_logs/{logId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);
      }

      match /body_measurements/{logId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);
      }

      match /daily_health_logs/{logId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);
      }
    }
  }
}