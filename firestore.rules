rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FUNÇÕES AUXILIARES
     */
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * EXERCÍCIOS GLOBAIS (BANCO DE DADOS)
     * Todos os usuários logados podem ler, mas ninguém pode alterar via app.
     */
    match /exercises/{exerciseId} {
      allow read: if isSignedIn();
    }

    /**
     * DADOS DO USUÁRIO (Silo Privado)
     * Implementa o modelo de Propriedade Total: 
     * Se o ID no caminho coincide com o ID do usuário logado, ele tem acesso total
     * a todos os documentos e subcoleções recursivamente.
     */
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /{allSubPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // Compatibilidade com rotas antigas de exercícios personalizados se existirem fora da subárvore /users/{userId}
    match /custom_exercises/{exerciseId} {
      allow read, write: if isSignedIn() && resource.data.creatorUserId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.creatorUserId == request.auth.uid;
    }
  }
}