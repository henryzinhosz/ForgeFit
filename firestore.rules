rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Silo de Dados do Usuário: Padrão Recursivo Absoluto
    // Garante que o usuário autenticado tenha acesso total e exclusivo a TUDO 
    // dentro do seu caminho /users/{userId}/, incluindo todas as subcoleções (metrics, workouts, etc.)
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Regras auxiliares para banco de exercícios (leitura pública para autenticados)
    match /exercises/{exerciseId} {
      allow read: if request.auth != null;
    }
  }
}