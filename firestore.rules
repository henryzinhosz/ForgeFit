
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * REGRAS DE SILO DO USUÁRIO
     * Permite acesso total (leitura e escrita) ao proprietário dos dados em seu próprio silo.
     * O wildcard {document=**} garante que todas as subcoleções (metrics, workouts, etc.) herdem a permissão.
     */
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Permite leitura e escrita no documento raiz do usuário
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    /**
     * EXERCÍCIOS GLOBAIS
     */
    match /exercises/{exerciseId} {
      allow read: if request.auth != null;
    }

    /**
     * EXERCÍCIOS PERSONALIZADOS
     */
    match /custom_exercises/{exerciseId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.creatorUserId == request.auth.uid);
    }
    
    // Deploy trigger: Ajuste de recursividade para garantir listagem em subcoleções privadas.
  }
}
