
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FUNÇÕES AUXILIARES
     */
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * EXERCÍCIOS GLOBAIS
     */
    match /exercises/{exerciseId} {
      allow read: if isSignedIn();
    }

    /**
     * SILO PRIVADO DO USUÁRIO
     * Regras robustas que permitem ao proprietário total controle sobre seu silo.
     */
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      // Permite acesso recursivo a todas as subcoleções (metrics, workouts, etc.)
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    /**
     * COMPATIBILIDADE: Exercícios personalizados
     */
    match /custom_exercises/{exerciseId} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.creatorUserId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.creatorUserId == request.auth.uid;
    }
    
    // Deploy trigger: Ajuste final para garantir permissão de listagem em subcoleções.
  }
}
