rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGRA DE OURO: Silo Absoluto e Recursivo por Usuário
    // O padrão {document=**} garante que o dono do ID tenha acesso total a 
    // QUALQUER documento ou subcoleção (metrics, workouts, water, meals) sem ambiguidades.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Banco de Exercícios: Apenas leitura para usuários logados
    match /exercises/{exerciseId} {
      allow read: if request.auth != null;
    }
  }
}