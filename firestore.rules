rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FUNÇÕES AUXILIARES
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * EXERCÍCIOS GLOBAIS
     */
    match /exercises/{exerciseId} {
      allow read: if isSignedIn();
    }

    /**
     * SILO PRIVADO DO USUÁRIO
     * Estrutura aninhada para garantir que tanto o documento do usuário
     * quanto todas as suas subcoleções (workouts, metrics, water, meals)
     * sejam acessíveis apenas pelo proprietário.
     */
    match /users/{userId} {
      // Permite acesso ao documento raiz do usuário
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      
      // Permite acesso recursivo a todas as subcoleções e documentos internos
      match /{allPaths=**} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    /**
     * COMPATIBILIDADE: Exercícios personalizados legados
     */
    match /custom_exercises/{exerciseId} {
      allow read, write: if isSignedIn() && resource.data.creatorUserId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.creatorUserId == request.auth.uid;
    }
    
    // Deploy trigger: Atualização das regras para corrigir erro de listagem no silo do usuário.
  }
}