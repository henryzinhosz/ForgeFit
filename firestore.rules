
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SILO DE DADOS DO USUÁRIO
     * Regras explícitas para evitar erros de permissão em listagens (queries).
     */
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Permissões explícitas para todas as subcoleções conhecidas
      match /workouts/{id} { allow read, write: if request.auth != null && request.auth.uid == userId; }
      match /metrics/{id} { allow read, write: if request.auth != null && request.auth.uid == userId; }
      match /water/{id} { allow read, write: if request.auth != null && request.auth.uid == userId; }
      match /meals/{id} { allow read, write: if request.auth != null && request.auth.uid == userId; }
      
      // Catch-all para qualquer outra subcoleção futura
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    /**
     * EXERCÍCIOS GLOBAIS
     */
    match /exercises/{exerciseId} {
      allow read: if request.auth != null;
    }

    /**
     * EXERCÍCIOS PERSONALIZADOS
     */
    match /custom_exercises/{exerciseId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (resource == null || resource.data.creatorUserId == request.auth.uid);
    }
  }
}
