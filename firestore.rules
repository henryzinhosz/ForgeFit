rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FUNÇÕES AUXILIARES
     */
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * EXERCÍCIOS GLOBAIS (BANCO DE DADOS)
     * Todos os usuários logados podem ler o banco de dados de exercícios padrão.
     */
    match /exercises/{exerciseId} {
      allow read: if isSignedIn();
    }

    /**
     * SILO PRIVADO DO USUÁRIO
     * Esta regra garante acesso total (leitura e escrita) ao documento do usuário
     * e a QUALQUER subcoleção aninhada (workouts, metrics, water, meals, etc).
     */
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    /**
     * EXERCÍCIOS PERSONALIZADOS (Legado/Compatibilidade)
     */
    match /custom_exercises/{exerciseId} {
      allow read, write: if isSignedIn() && resource.data.creatorUserId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.creatorUserId == request.auth.uid;
    }
  }
}