rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FUNÇÕES AUXILIARES
     */
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * EXERCÍCIOS GLOBAIS
     */
    match /exercises/{exerciseId} {
      allow read: if isSignedIn();
    }

    /**
     * SILO PRIVADO DO USUÁRIO
     * Estrutura explícita para garantir que subcoleções como 'metrics'
     * permitam operações de listagem e leitura sem bloqueios.
     */
    match /users/{userId} {
      // Permite acesso ao documento raiz do perfil
      allow read, write: if isOwner(userId);
      
      // Permite acesso a qualquer documento em qualquer subcoleção (workouts, metrics, water, meals)
      match /{collectionName}/{docId} {
        allow read, write: if isOwner(userId);
      }
      
      // Garantia recursiva para caminhos mais profundos
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    /**
     * COMPATIBILIDADE: Exercícios personalizados
     */
    match /custom_exercises/{exerciseId} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.creatorUserId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.creatorUserId == request.auth.uid;
    }
    
    // Deploy trigger: Ajuste final de granularidade para resolver erro de listagem em /metrics.
  }
}