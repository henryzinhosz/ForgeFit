rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regra de Ouro: Isolamento Total por Usuário
    // Cada usuário só pode ler e escrever em sua própria "pasta" (documento e subcoleções)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Permissões explícitas para subcoleções (necessário para consultas complexas com filtros)
      match /metrics/{metricId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /workouts/{workoutId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /water/{waterId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /meals/{mealId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Banco de Exercícios: Apenas leitura para usuários logados
    match /exercises/{exerciseId} {
      allow read: if request.auth != null;
    }
  }
}